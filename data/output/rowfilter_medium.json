anagers()\nRETURNS BOOLEAN\nRETURN IF(\n  IS_ACCOUNT_GROUP_MEMBER('regional_managers'),\n  region IN ('WEST', 'CENTRAL') AND order_date >= '2024-01-01',\n  TRUE  -- Allow all for non-matching groups (adjust as needed)\n);\n\nALTER TABLE main.sales.transactions\nSET ROW FILTER main.sales.rf_transactions_regional_managers ON ();\n\n-- \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n-- Policy: sales_data_filters (Ranger ID: 102)\n-- Type: ROW_FILTER | Principal: sales_analysts\n-- \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n-- Row Filter for: sales_analysts\n-- Original expression: department = 'SALES' AND status = 'ACTIVE'\n\nCREATE OR REPLACE FUNCTION main.sales.rf_transactions_sales_analysts()\nRETURNS BOOLEAN\nRETURN IF(\n  IS_ACCOUNT_GROUP_MEMBER('sales_analysts'),\n  department = 'SALES' AND status = 'ACTIVE',\n  TRUE  -- Allow all for non-matching groups (adjust as needed)\n);\n\nALTER TABLE main.sales.transactions\nSET ROW FILTER main.sales.rf_transactions_sales_analysts ON ();\n\n-- \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n-- Policy: sales_data_filters (Ranger ID: 102)\n-- Type: ROW_FILTER | Principal: executives\