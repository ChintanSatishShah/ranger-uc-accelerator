 that principal.\n\nCREATE OR REPLACE FUNCTION `main`.`sales`.rf_transactions(region STRING, order_date STRING, department STRING, status STRING)\nRETURNS BOOLEAN\nRETURN\n  CASE\n    WHEN IS_ACCOUNT_GROUP_MEMBER('regional_managers') THEN region IN ('WEST', 'CENTRAL') AND order_date >= '2024-01-01'\n    WHEN IS_ACCOUNT_GROUP_MEMBER('sales_analysts') THEN department = 'SALES' AND status = 'ACTIVE'\n    WHEN IS_ACCOUNT_GROUP_MEMBER('executives') THEN TRUE\n    ELSE TRUE  -- allow access for all other principals\n  END;\n\nALTER TABLE `main`.`sales`.`transactions`\nSET ROW FILTER `main`.`sales`.rf_transactions ON (region, order_date, department, status);\n"
